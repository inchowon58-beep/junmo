# 네이버 검색 API (애플리케이션 등록 시 「검색」 선택)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Gemini API (SEO 페이지 자동 생성)
GEMINI_API_KEY=

# 사이트 URL (sitemap, OG 이미지 등)
SITE_URL=https://sim-seven-woad.vercel.app

# Vercel 배포 시: Storage → Blob 연결 시 자동 설정 (OIDC)
# BLOB_STORE_ID=store_...
# BLOB_ACCESS=private
# BLOB_PREFIX=agapet-shelter

# 멀티 테넌트 (Supabase + Vercel API) — 신규 서브도메인 사이트용
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role키
VERCEL_TOKEN=
VERCEL_PROJECT_ID=prj_xxxxxxxx
# VERCEL_PROJECT_NAME=sim
# VERCEL_TEAM_ID=team_xxxxxxxx

# Cron·워커 (선택)
# CRON_SECRET=
# COLLECTION_WORKER_SECRET=
# SLACK_INQUIRY_WEBHOOK_URL=

# 선택: 레거시 단일 사이트 env 폴백
# NEXT_PUBLIC_BRAND_NAME=아가펫보호소
# NEXT_PUBLIC_SITE_URL=
